// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  profile Profile?
  quizAttempts QuizAttempt[]
  chatMessages ChatMessage[]
  bookmarks SchoolBookmark[]
}

enum Route {
  NDA
  CIVILIAN
  UNDECIDED
}

enum Stage {
  TENTH
  TWELFTH
  AFTER_TWELFTH
  AFTER_GRADUATION
}

model Profile {
  id            String    @id @default(uuid())
  userId        String    @unique
  currentStage  Stage
  chosenRoute   Route     @default(UNDECIDED)
  budgetLakhs   Int?
  dateOfBirth   DateTime?
  colorBlind    Boolean   @default(false)
  visionIssues  Boolean   @default(false)
  bpIssues      Boolean   @default(false)
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  progress      Progress[]
}

model RoadmapStep {
  id              String   @id @default(uuid())
  route           Route
  stepOrder       Int
  title           String
  description     String
  estCostLakhs    Float?
  estDuration     String?
  estDurationMonths Float?
  progress        Progress[]
}

model Progress {
  id            String   @id @default(uuid())
  profileId     String
  stepId        String
  completed     Boolean  @default(false)
  completedAt   DateTime?

  profile       Profile     @relation(fields: [profileId], references: [id])
  step          RoadmapStep @relation(fields: [stepId], references: [id])

  @@unique([profileId, stepId])
}

model FlyingSchool {
  id          String  @id @default(uuid())
  name        String
  city        String
  state       String
  ownership   String
  feeMinLakhs Float
  feeMaxLakhs Float
  fleetType   String
  website     String?
  bookmarks SchoolBookmark[]
}

model QuizQuestion {
  id            String  @id @default(uuid())
  topic         String
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  explanation   String?
}


model QuizAttempt {
  id             String   @id @default(uuid())
  userId         String
  topic          String
  score          Int
  totalQuestions Int
  takenAt        DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id])
  answers        AttemptAnswer[]
}

model KnowledgeChunk {
  id        String                       @id @default(uuid())
  topic     String
  content   String
  embedding Unsupported("vector(768)")?
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String
  content   String
  sources   String[]
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model AttemptAnswer {
  id         String   @id @default(uuid())
  attemptId  String
  topic      String
  isCorrect  Boolean

  attempt    QuizAttempt @relation(fields: [attemptId], references: [id])
}

model SchoolBookmark {
  id        String   @id @default(uuid())
  userId    String
  schoolId  String
  createdAt DateTime @default(now())

  user      User         @relation(fields: [userId], references: [id])
  school    FlyingSchool @relation(fields: [schoolId], references: [id])

  @@unique([userId, schoolId])
}